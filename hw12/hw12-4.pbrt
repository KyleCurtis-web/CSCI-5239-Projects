#a Meeple
AttributeBegin
    # Define textures using PNG files
    Texture "wood-color" "spectrum" "imagemap" 
        "string filename" "wood_color.png"

    Texture "pure-red" "spectrum" "constant" "rgb value" [1 0 0]

    Texture "tinted-wood" "spectrum" "mix"
    "texture tex1" "wood-color"
    "texture tex2" "pure-red"  # The color you want to shift toward
    "float amount" 0.5          # 0.0 = tex1, 1.0 = tex2


    #define the roughness
    Texture "wood-roughness" "float" "imagemap" 
        "string filename" "wood_roughness.png"

    # Apply to the material
    MakeNamedMaterial "WoodMaterial"
        "string type" "coateddiffuse"
        #"texture reflectance" "wood-color"
        "texture reflectance" "tinted-wood"
        "texture roughness" "wood-roughness"
    NamedMaterial "WoodMaterial"
    Scale 0.1 0.1 0.1
    Translate 0 0 -3
    Rotate 180 1 0 0
