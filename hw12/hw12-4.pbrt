#a teapot
AttributeBegin
   #  Matte material with cbtex as texture
   Material "dielectric"
   #  rotate 90 degrees and scale down
      Scale 0.5 0.5 0.5
      Translate 0 -5 -2
      Rotate 90 1 0 0
